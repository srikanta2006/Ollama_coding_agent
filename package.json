{
  "name": "ollama-coding-agent",
  "version": "1.0.0",
  "description": "Pipeline to run both frontend and backend concurrently",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "npm start --prefix frontend",
    "start:backend": "cd backend && .\\venv\\Scripts\\python -m uvicorn api:app --reload --port 8000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
